{
  "name": "beanconqueror",
  "version": "2.0.0",
  "author": "Lars Saalbach",
  "homepage": "https://github.com/graphefruit/beanconqueror",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test --browsers=ChromeHeadless --watch=false",
    "test:dev": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "prepare": "husky",
    "generate_proto": "protoc --plugin=node_modules/ts-proto/protoc-gen-ts_proto  --ts_proto_opt=snakeToCamel=false --ts_proto_opt=esModuleInterop=true --ts_proto_out ./src/generated ./src/classes/bean/bean.proto",
    "ionic": "ionic",
    "cap": "capacitor",
    "capsync": "capacitor sync android && capacitor sync ios",
    "generate-icon-registry": "node tools/generate-icon-registry.mjs > src/generated/icon-registry.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@aparajita/capacitor-dark-mode": "^6.0.0",
    "@awesome-cordova-plugins/android-permissions": "^9.1.4",
    "@awesome-cordova-plugins/core": "^9.1.4",
    "@bufbuild/protobuf": "^2.11.0",
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/app-launcher": "^8.0.1",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "8.0.0",
    "@capacitor/geolocation": "8.0.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-android-edge-to-edge-support": "^8.0.8",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@capgo/camera-preview": "^8.3.1",
    "@capgo/capacitor-llm": "^8.0.11",
    "@ionic/angular": "^8.8.4",
    "@ionic/cli": "^7.2.1",
    "@ionic/core": "^8.8.4",
    "@ionic/storage": "^4.0.0",
    "@ionic/storage-angular": "^4.0.0",
    "@mediapipe/tasks-genai": "^0.10.27",
    "@meticulous-home/espresso-api": "^0.10.12",
    "@meticulous-home/espresso-profile": "^0.4.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@pantrist/capacitor-plugin-ml-kit-text-recognition": "^8.0.0",
    "@zip.js/zip.js": "^2.8.26",
    "ag-virtual-scroll": "~1.20.2",
    "ble-central-advertisements": "^1.1.0",
    "chart.js": "^4.5.1",
    "community-cordova-plugin-nfc": "^1.6.0",
    "currency-symbol-map": "^5.1.0",
    "html-to-image": "^1.11.13",
    "ionicons": "^8.0.13",
    "javascript-color-gradient": "^2.5.0",
    "localforage-cordovasqlitedriver": "^1.8.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "moment": "^2.30.1",
    "ngx-stars": "^1.6.5",
    "qrcode": "^1.5.4",
    "regression": "^2.0.1",
    "rxjs": "^7.8.2",
    "safe-stable-stringify": "^2.5.0",
    "serialize-error": "^13.0.1",
    "swiper": "^12.1.3",
    "tslib": "^2.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zone.js": "^0.16.1",
    "@angular/service-worker": "^21.2.9"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2100.6",
    "@angular-devkit/schematics": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler": "^21.2.9",
    "@angular/compiler-cli": "^21.2.9",
    "@angular/language-service": "^21.2.9",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@ionic/angular-toolkit": "^12.3.0",
    "@types/jasmine": "^5.1.15",
    "@types/jasminewd2": "~2.0.13",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "angular-eslint": "^21.3.1",
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-ble-central": "^2.0.0",
    "cordova-plugin-health": "^2.1.1",
    "cordova-sqlite-storage": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jasmine-core": "^5.13.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "skwas-cordova-plugin-datetimepicker": "^3.0.2",
    "ts-proto": "^2.11.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "description": "Beanconqueror",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.26.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  },
  "platforms": [
    "android",
    "ios"
  ],
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "<BUILTIN_MODULES>",
      "",
      "^@angular",
      "",
      "^@ionic",
      "^ionicons",
      "",
      "<THIRD_PARTY_MODULES>",
      "",
      "^src/",
      "^[.]"
    ],
    "importOrderParserPlugins": [
      "typescript",
      "decorators"
    ]
  },
  "lint-staged": {
    "*.{ts,js,css,md}": "prettier --write"
  }
}
