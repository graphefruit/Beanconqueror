<?xml version="1.0"?>
<Container version="2">
  <Name>Beanconqueror</Name>
  <Repository>ghcr.io/salthepal/beanconqueror:latest</Repository>
  <Registry>https://github.com/salthepal/Beanconqueror/pkgs/container/beanconqueror</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/salthepal/Beanconqueror/issues</Support>
  <Project>https://github.com/salthepal/Beanconqueror</Project>
  <Overview>Beanconqueror web app with a bundled API for server-side MariaDB persistence and local Gaggiuino API imports. Install or configure a MariaDB container on the same Unraid server, then point DB_HOST/credentials at it.</Overview>
  <Category>Productivity:Tools</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/salthepal/Beanconqueror/HEAD/unraid/beanconqueror.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/salthepal/Beanconqueror/HEAD/src/assets/icon/favicon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>MariaDB or compatible MySQL database reachable from this container.</Requires>
  <Config Name="WebUI" Target="80" Default="8080" Mode="tcp" Description="Container web interface port." Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="API_BASE_URL" Target="API_BASE_URL" Default="/api" Mode="" Description="Browser API base URL. Keep /api when using the bundled API behind Nginx." Type="Variable" Display="advanced" Required="true" Mask="false">/api</Config>
  <Config Name="DB_HOST" Target="DB_HOST" Default="mariadb" Mode="" Description="MariaDB host/container name." Type="Variable" Display="always" Required="true" Mask="false">mariadb</Config>
  <Config Name="DB_PORT" Target="DB_PORT" Default="3306" Mode="" Description="MariaDB port." Type="Variable" Display="advanced" Required="true" Mask="false">3306</Config>
  <Config Name="DB_NAME" Target="DB_NAME" Default="beanconqueror" Mode="" Description="MariaDB database name." Type="Variable" Display="always" Required="true" Mask="false">beanconqueror</Config>
  <Config Name="DB_USER" Target="DB_USER" Default="beanconqueror" Mode="" Description="MariaDB username." Type="Variable" Display="always" Required="true" Mask="false">beanconqueror</Config>
  <Config Name="DB_PASSWORD" Target="DB_PASSWORD" Default="" Mode="" Description="MariaDB password." Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="GAGGIUINO_BASE_URL" Target="GAGGIUINO_BASE_URL" Default="http://gaggiuino.local" Mode="" Description="Local Gaggiuino API URL. Use a fixed LAN IP if mDNS does not resolve from Docker." Type="Variable" Display="always" Required="false" Mask="false">http://gaggiuino.local</Config>
  <Config Name="GAGGIUINO_TIMEOUT_MS" Target="GAGGIUINO_TIMEOUT_MS" Default="5000" Mode="" Description="Gaggiuino request timeout in milliseconds." Type="Variable" Display="advanced" Required="false" Mask="false">5000</Config>
  <Config Name="FEATURE_FLAGS_JSON" Target="FEATURE_FLAGS_JSON" Default="{}" Mode="" Description="Optional JSON object injected into /assets/env.js at container start." Type="Variable" Display="advanced" Required="false" Mask="false">{}</Config>
</Container>
